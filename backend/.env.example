# Configurações do BOT
# Chaves de API válidas para BOTs (separadas por vírgula)
BOT_API_KEYS=bot-key-123,scan-agent-456,privacy-bot-789

# Exemplo de .env adicional para o sistema de upload
# Diretório de upload (padrão: uploads/scan-data)
SCAN_UPLOAD_DIR=uploads/scan-data

# Tamanho máximo por arquivo (em bytes, padrão: 100MB)
MAX_FILE_SIZE=104857600

# Número máximo de arquivos por request (padrão: 10)
MAX_FILES_PER_REQUEST=10

# RBAC e Autenticação
DEFAULT_ORGANIZATION_ID=1
DEFAULT_USER_ROLE=cliente
JWT_SECRET=troque-esta-chave
JWT_EXPIRES_IN=7d

# Banco de Dados (usar sslmode=require em produção)
DATABASE_URL=postgres://user:senha@host:5432/dbname

# SSL do Banco
# Colar o certificado raiz (CA) em PEM uma única linha ou com quebras. Exemplo:
# CA_CERT="-----BEGIN CERTIFICATE-----\nABC...\n-----END CERTIFICATE-----"
# Modo strict exige CA; system ignora CA mas verifica; system-allow-self-signed desativa verificação; usar strict em produção.
DB_SSL_MODE=strict
# CA_CERT=-----BEGIN CERTIFICATE-----
# COLE_O_CERT_PRODUCAO_AQUI
# -----END CERTIFICATE-----


# Passwordless Magic Link
ENABLE_MAGIC_LINK=true
MAGIC_LINK_TTL=900
INVITE_TTL=604800
VERIFY_EMAIL_TTL=86400
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# MailerSend
MAILERSEND_API_KEY=coloque-seu-token-mailersend-aqui
MAIL_FROM=no-reply@seusdados.com
